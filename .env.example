# Copy this to .env and fill in your values

BOT_TOKEN=your_telegram_bot_token_here
CHANNEL_ID=@your_channel_or_-100xxxxxxxxxx

# Optional — defaults shown
POLL_INTERVAL=3600   # seconds between cycles
TEST_WORKERS=50      # parallel xray processes during ping test
TEST_TIMEOUT=5.0     # seconds each config gets to respond
TOP_N=10             # number of best configs to send
